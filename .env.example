# DemandOrchestrator env
APP_ENV=development
API_PORT=8000
WEB_PORT=3000
DATABASE_URL=sqlite:///./demandorchestrator.db
OPENAI_API_KEY=

# Publishing adapter
PUBLISH_PROVIDER_MODE=stub
# for webhook mode
PUBLISH_PROVIDER_URL=http://127.0.0.1:8000/relay/publish
PUBLISH_PROVIDER_TOKEN=

# Relay security
RELAY_SHARED_TOKEN=

# X relay credentials
X_BEARER_TOKEN=
X_USER_ID=
X_MENTION_STATE_PATH=./apps/api/x_mentions_state.json
X_REPLY_DRAFT_QUEUE_PATH=./apps/api/x_reply_drafts.ndjson
X_AUTO_REPLY_ENABLED=false

# LinkedIn relay credentials
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# Apify integration
APIFY_TOKEN=
APIFY_BASE_URL=https://api.apify.com/v2
APIFY_TIMEOUT_SECONDS=30

# HeyGen video integration
HEYGEN_API_KEY=
HEYGEN_API_BASE=https://api.heygen.com
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# Waitlist instant email alerts
WAITLIST_ALERT_TO_EMAIL=
WAITLIST_APPROVAL_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# future
# POSTGRES_URL=
# REDIS_URL=
